---
import type { Paper } from "../lib/types";
import { KEYWORD_GROUPS } from "../lib/papers";

interface Props {
  paper: Paper;
}

const { paper } = Astro.props;

const keywordSlugs = new Set(KEYWORD_GROUPS.map((g) => g.slug));
const highlightTags = paper.tags.filter((t) => keywordSlugs.has(t));
const otherTags = paper.tags.filter((t) => !keywordSlugs.has(t));

const hasMemo = paper.memo.trim().length > 0;
const venueStatus = paper.venue_status ?? "preprint";
const searchBlob = [paper.title, paper.authors.join(" "), paper.abstract, paper.tags.join(" ")]
  .join(" ")
  .toLowerCase();
---

<article
  class="paper-card flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md"
  data-id={paper.id}
  data-title={paper.title}
  data-category={paper.category}
  data-conference={paper.conference ?? ""}
  data-tags={paper.tags.join(",")}
  data-has-memo={hasMemo ? "1" : "0"}
  data-award={paper.award ? "1" : "0"}
  data-venue-status={venueStatus}
  data-published={paper.published_date}
  data-search={searchBlob}
>
  <div class="flex flex-wrap items-center gap-2 text-xs font-medium">
    {venueStatus === "published" ? (
      <span
        class="rounded-full bg-emerald-100 px-2.5 py-1 text-emerald-800"
        title={paper.venue_note ?? undefined}
      >✅ 採択・出版済み</span>
    ) : (
      <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-500">📝 プレプリント</span>
    )}
    <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700">{paper.category}</span>
    {paper.conference && (
      <span class="rounded-full bg-indigo-100 px-2.5 py-1 text-indigo-700">{paper.conference}</span>
    )}
    {paper.award && (
      <span class="rounded-full bg-amber-100 px-2.5 py-1 text-amber-800">🏆 {paper.award}</span>
    )}
    <span class="ml-auto flex items-center gap-1">
      <button
        type="button"
        class="favorite-toggle inline-flex h-7 w-7 items-center justify-center rounded-full text-lg leading-none text-slate-300 opacity-40 grayscale transition hover:opacity-70"
        aria-pressed="false"
        title="お気に入り"
      >☆</button>
      <button
        type="button"
        class="readlater-toggle inline-flex h-7 w-7 items-center justify-center rounded-full text-base leading-none opacity-40 grayscale transition hover:opacity-70"
        aria-pressed="false"
        title="あとで読む"
      >🔖</button>
    </span>
  </div>

  <h2 class="text-lg font-semibold leading-snug text-slate-900">
    <a href={paper.url} target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 hover:underline">
      {paper.title}
    </a>
  </h2>

  <p class="text-sm text-slate-500">{paper.authors.join(", ")}</p>
  <p class="text-xs text-slate-400">{paper.published_date}</p>

  {(highlightTags.length > 0 || otherTags.length > 0) && (
    <div class="flex flex-wrap gap-1.5">
      {highlightTags.map((tag) => (
        <span class="rounded-md bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800">{tag}</span>
      ))}
      {otherTags.map((tag) => (
        <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{tag}</span>
      ))}
    </div>
  )}

  <details class="text-sm text-slate-600">
    <summary class="cursor-pointer select-none font-medium text-slate-700 hover:text-indigo-600">要旨を表示</summary>
    <p class="mt-2 leading-relaxed">{paper.abstract}</p>
  </details>

  <div class="mt-1 rounded-lg bg-slate-50 p-3 text-sm" data-memo-section>
    <div data-memo-display>
      {hasMemo ? (
        <>
          <p class="whitespace-pre-wrap text-slate-700" data-memo-text>{paper.memo}</p>
          {paper.memo_updated_at && (
            <p class="mt-1 text-xs text-slate-400" data-memo-updated-at>更新: {paper.memo_updated_at}</p>
          )}
        </>
      ) : (
        <p class="text-slate-400" data-memo-text>メモなし</p>
      )}
    </div>

    <button type="button" class="memo-edit-toggle mt-2 text-xs font-medium text-indigo-600 hover:underline">
      メモを編集
    </button>

    <div class="memo-edit-form mt-2 hidden">
      <textarea
        class="memo-textarea w-full rounded border border-slate-300 p-2 text-sm"
        rows="3"
        placeholder="メモを入力してください"
      >{paper.memo}</textarea>
      <div class="mt-2 flex items-center gap-3">
        <button
          type="button"
          class="memo-save-btn rounded bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-indigo-700"
        >GitHub Issueで保存</button>
        <button type="button" class="memo-cancel-btn text-xs text-slate-400 hover:underline">キャンセル</button>
      </div>
      <p class="mt-2 text-xs text-slate-400">
        押すとGitHubのIssue作成画面が新しいタブで開きます。内容を確認して送信すると、数分以内にこのメモが自動反映されます。
      </p>
    </div>
  </div>
</article>
