---
import Layout from "../layouts/Layout.astro";
import PaperCard from "./PaperCard.astro";
import { papers as allPapers, categories, conferences, KEYWORD_GROUPS } from "../lib/papers";
import type { Paper } from "../lib/types";

interface PaginatedPage<T> {
  data: T[];
  start: number;
  end: number;
  size: number;
  total: number;
  currentPage: number;
  lastPage: number;
  url: { current: string; prev?: string; next?: string };
}

interface Props {
  page: PaginatedPage<Paper>;
  sortMode: "newest" | "award";
}

const { page, sortMode } = Astro.props;
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO || "KeitoTsubaki/research_tracker";
const base = import.meta.env.BASE_URL;
const keywordSlugs = KEYWORD_GROUPS.map((g) => g.slug).join(",");
---

<Layout>
  <div
    class="mx-auto max-w-5xl px-4 py-8"
    data-github-repo={githubRepo}
    data-base-url={base}
    data-sort-mode={sortMode}
    data-keyword-slugs={keywordSlugs}
  >
    <header class="mb-6">
      <h1 class="text-2xl font-bold text-slate-900">研究論文トラッカー</h1>
      <p class="mt-1 text-sm text-slate-500">
        マルチエージェント強化学習・協調ロボット搬送・自動運転関連の論文を自動収集します(全{allPapers.length}件)。
        <a class="text-indigo-600 hover:underline" href={`${base}rss.xml`}>RSS</a>
      </p>
    </header>

    <section class="mb-6 flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <input
          id="search"
          type="search"
          placeholder="キーワード検索(全件対象: タイトル・著者・要旨・タグ)"
          class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none"
        />
        <select id="categoryFilter" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
          <option value="">カテゴリ: すべて</option>
          {categories.map((c) => <option value={c}>{c}</option>)}
        </select>
        <select id="conferenceFilter" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
          <option value="">会議: すべて</option>
          {conferences.map((c) => <option value={c}>{c}</option>)}
        </select>
        <select id="memoFilter" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
          <option value="">メモ: すべて</option>
          <option value="with">メモあり</option>
          <option value="without">メモなし</option>
        </select>
        <select id="sortSelect" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
          <option value="newest" selected={sortMode === "newest"}>新着順</option>
          <option value="award" selected={sortMode === "award"}>会議受賞順</option>
        </select>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm">
        <span class="font-medium text-slate-600">タグ:</span>
        {KEYWORD_GROUPS.map((g) => (
          <label class="flex items-center gap-1.5">
            <input type="checkbox" class="tag-filter rounded" data-tag={g.slug} />
            {g.label}
          </label>
        ))}
        <select id="tagMode" class="rounded-lg border border-slate-300 px-2 py-1 text-xs" title="複数タグを選んだときの条件">
          <option value="or">タグ: いずれか(OR)</option>
          <option value="and">タグ: すべて(AND)</option>
        </select>
        <span class="mx-1 h-4 w-px bg-slate-200"></span>
        <label class="flex items-center gap-1.5">
          <input type="checkbox" id="favoritesOnlyFilter" class="rounded" />
          ☆ お気に入りのみ
        </label>
        <label class="flex items-center gap-1.5">
          <input type="checkbox" id="readlaterOnlyFilter" class="rounded" />
          🔖 あとで読むのみ
        </label>
        <button id="resetFilters" type="button" class="ml-auto text-slate-400 hover:text-indigo-600 hover:underline">
          フィルタをリセット
        </button>
      </div>
    </section>

    <p class="mb-3 text-sm text-slate-500">
      <span id="pageRangeLabel">このページ: 全{allPapers.length}件中 {page.start + 1}〜{page.end + 1}件目 </span>
      (<span id="resultCount"></span>)
    </p>

    <div id="cardGrid" class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {page.data.map((paper) => <PaperCard paper={paper} />)}
    </div>

    <p id="emptyState" class="hidden py-12 text-center text-sm text-slate-400">
      条件に一致する論文が見つかりませんでした。
    </p>

    <div class="mt-6 flex justify-center">
      <button
        id="loadMoreBtn"
        type="button"
        class="hidden rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50"
      >
        もっと見る
      </button>
    </div>

    <nav id="pageNav" class="mt-8 flex items-center justify-center gap-4 text-sm">
      {page.url.prev ? (
        <a href={page.url.prev} class="rounded-lg border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">
          ← 前へ
        </a>
      ) : (
        <span class="rounded-lg border border-slate-200 px-3 py-1.5 text-slate-300">← 前へ</span>
      )}
      <span class="text-slate-500">{page.currentPage} / {page.lastPage} ページ</span>
      {page.url.next ? (
        <a href={page.url.next} class="rounded-lg border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">
          次へ →
        </a>
      ) : (
        <span class="rounded-lg border border-slate-200 px-3 py-1.5 text-slate-300">次へ →</span>
      )}
    </nav>
  </div>
</Layout>

<script>
  const root = document.querySelector<HTMLElement>("[data-github-repo]")!;
  const githubRepo = root.dataset.githubRepo || "";
  const baseUrl = root.dataset.baseUrl || "/";
  const sortMode = root.dataset.sortMode === "award" ? "award" : "newest";
  const keywordSlugSet = new Set((root.dataset.keywordSlugs || "").split(",").filter(Boolean));

  const grid = document.getElementById("cardGrid")!;
  const originalCards = Array.from(grid.querySelectorAll<HTMLElement>(".paper-card"));
  const resultCount = document.getElementById("resultCount")!;
  const pageRangeLabel = document.getElementById("pageRangeLabel")!;
  const emptyState = document.getElementById("emptyState")!;
  const loadMoreBtn = document.getElementById("loadMoreBtn") as HTMLButtonElement;
  const pageNav = document.getElementById("pageNav")!;

  const searchInput = document.getElementById("search") as HTMLInputElement;
  const categoryFilter = document.getElementById("categoryFilter") as HTMLSelectElement;
  const conferenceFilter = document.getElementById("conferenceFilter") as HTMLSelectElement;
  const memoFilter = document.getElementById("memoFilter") as HTMLSelectElement;
  const sortSelect = document.getElementById("sortSelect") as HTMLSelectElement;
  const tagCheckboxes = Array.from(document.querySelectorAll<HTMLInputElement>(".tag-filter"));
  const tagModeSelect = document.getElementById("tagMode") as HTMLSelectElement;
  const favoritesOnlyFilter = document.getElementById("favoritesOnlyFilter") as HTMLInputElement;
  const readlaterOnlyFilter = document.getElementById("readlaterOnlyFilter") as HTMLInputElement;
  const resetButton = document.getElementById("resetFilters")!;

  // Sorting is baked into which set of static pages you're on (newest vs
  // award order), so switching it navigates to page 1 of that ordering
  // instead of reordering the DOM client-side.
  sortSelect.addEventListener("change", () => {
    window.location.href = sortSelect.value === "award" ? `${baseUrl}awards/` : baseUrl;
  });

  // --- Favorites / read-later: persisted client-side only (no backend),
  // so state is per-browser. Stored as JSON arrays of paper ids.
  const FAVORITES_KEY = "research-tracker:favorites";
  const READLATER_KEY = "research-tracker:readlater";

  function loadIdSet(key: string): Set<string> {
    try {
      const raw = localStorage.getItem(key);
      return new Set(raw ? (JSON.parse(raw) as string[]) : []);
    } catch {
      return new Set();
    }
  }

  function saveIdSet(key: string, set: Set<string>) {
    localStorage.setItem(key, JSON.stringify([...set]));
  }

  const favorites = loadIdSet(FAVORITES_KEY);
  const readLater = loadIdSet(READLATER_KEY);

  // Emoji glyphs ignore CSS `color`, so active/inactive is signaled with a
  // colored background pill plus opacity/grayscale/scale instead of color
  // alone - otherwise the read-later button gave no visible feedback at all.
  function applyToggleState(button: HTMLElement, active: boolean) {
    button.setAttribute("aria-pressed", String(active));
    button.classList.toggle("opacity-40", !active);
    button.classList.toggle("grayscale", !active);
    button.classList.toggle("opacity-100", active);
    button.classList.toggle("scale-110", active);

    if (button.classList.contains("favorite-toggle")) {
      button.textContent = active ? "★" : "☆";
      button.classList.toggle("bg-amber-100", active);
      button.classList.toggle("text-amber-500", active);
      button.classList.toggle("text-slate-300", !active);
    } else if (button.classList.contains("readlater-toggle")) {
      button.classList.toggle("bg-indigo-100", active);
      button.classList.toggle("ring-1", active);
      button.classList.toggle("ring-indigo-300", active);
    }
  }

  for (const card of originalCards) {
    const id = card.dataset.id!;
    const favBtn = card.querySelector<HTMLElement>(".favorite-toggle");
    const laterBtn = card.querySelector<HTMLElement>(".readlater-toggle");
    if (favBtn) applyToggleState(favBtn, favorites.has(id));
    if (laterBtn) applyToggleState(laterBtn, readLater.has(id));
  }

  // --- Cross-page search: the page only ships the current 30-paper slice
  // to stay light, so any active filter fetches the full archive (once,
  // lazily) and renders matches from it instead of just hiding/showing the
  // cards already on the page.
  interface RemotePaper {
    id: string;
    title: string;
    authors: string[];
    category: string;
    conference: string | null;
    award: string | null;
    url: string;
    abstract: string;
    published_date: string;
    tags: string[];
    memo: string;
    memo_updated_at: string | null;
  }

  const DATA_URL = `${baseUrl}data.json`;
  let fullIndexPromise: Promise<RemotePaper[]> | null = null;
  function ensureIndexLoaded(): Promise<RemotePaper[]> {
    if (!fullIndexPromise) {
      fullIndexPromise = fetch(DATA_URL).then((r) => r.json());
    }
    return fullIndexPromise;
  }

  function escapeHtml(value: string): string {
    return value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function renderCardElement(paper: RemotePaper): HTMLElement {
    const hasMemo = paper.memo.trim().length > 0;
    const tags = paper.tags || [];
    const highlightTags = tags.filter((t) => keywordSlugSet.has(t));
    const otherTags = tags.filter((t) => !keywordSlugSet.has(t));
    const searchBlob = [paper.title, paper.authors.join(" "), paper.abstract, tags.join(" ")].join(" ").toLowerCase();

    const wrapper = document.createElement("div");
    wrapper.innerHTML = `
      <article class="paper-card flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md"
        data-id="${escapeHtml(paper.id)}"
        data-title="${escapeHtml(paper.title)}"
        data-category="${escapeHtml(paper.category)}"
        data-conference="${escapeHtml(paper.conference ?? "")}"
        data-tags="${escapeHtml(tags.join(","))}"
        data-has-memo="${hasMemo ? "1" : "0"}"
        data-award="${paper.award ? "1" : "0"}"
        data-published="${escapeHtml(paper.published_date)}"
        data-search="${escapeHtml(searchBlob)}"
      >
        <div class="flex flex-wrap items-center gap-2 text-xs font-medium">
          <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700">${escapeHtml(paper.category)}</span>
          ${paper.conference ? `<span class="rounded-full bg-indigo-100 px-2.5 py-1 text-indigo-700">${escapeHtml(paper.conference)}</span>` : ""}
          ${paper.award ? `<span class="rounded-full bg-amber-100 px-2.5 py-1 text-amber-800">🏆 ${escapeHtml(paper.award)}</span>` : ""}
          <span class="ml-auto flex items-center gap-1">
            <button type="button" class="favorite-toggle inline-flex h-7 w-7 items-center justify-center rounded-full text-lg leading-none text-slate-300 opacity-40 grayscale transition hover:opacity-70" aria-pressed="false" title="お気に入り">☆</button>
            <button type="button" class="readlater-toggle inline-flex h-7 w-7 items-center justify-center rounded-full text-base leading-none opacity-40 grayscale transition hover:opacity-70" aria-pressed="false" title="あとで読む">🔖</button>
          </span>
        </div>

        <h2 class="text-lg font-semibold leading-snug text-slate-900">
          <a href="${escapeHtml(paper.url)}" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 hover:underline">${escapeHtml(paper.title)}</a>
        </h2>

        <p class="text-sm text-slate-500">${escapeHtml(paper.authors.join(", "))}</p>
        <p class="text-xs text-slate-400">${escapeHtml(paper.published_date)}</p>

        ${
          highlightTags.length > 0 || otherTags.length > 0
            ? `<div class="flex flex-wrap gap-1.5">
                ${highlightTags.map((t) => `<span class="rounded-md bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800">${escapeHtml(t)}</span>`).join("")}
                ${otherTags.map((t) => `<span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600">${escapeHtml(t)}</span>`).join("")}
              </div>`
            : ""
        }

        <details class="text-sm text-slate-600">
          <summary class="cursor-pointer select-none font-medium text-slate-700 hover:text-indigo-600">要旨を表示</summary>
          <p class="mt-2 leading-relaxed">${escapeHtml(paper.abstract)}</p>
        </details>

        <div class="mt-1 rounded-lg bg-slate-50 p-3 text-sm" data-memo-section>
          <div data-memo-display>
            ${
              hasMemo
                ? `<p class="whitespace-pre-wrap text-slate-700" data-memo-text>${escapeHtml(paper.memo)}</p>${
                    paper.memo_updated_at
                      ? `<p class="mt-1 text-xs text-slate-400" data-memo-updated-at>更新: ${escapeHtml(paper.memo_updated_at)}</p>`
                      : ""
                  }`
                : `<p class="text-slate-400" data-memo-text>メモなし</p>`
            }
          </div>
          <button type="button" class="memo-edit-toggle mt-2 text-xs font-medium text-indigo-600 hover:underline">メモを編集</button>
          <div class="memo-edit-form mt-2 hidden">
            <textarea class="memo-textarea w-full rounded border border-slate-300 p-2 text-sm" rows="3" placeholder="メモを入力してください">${escapeHtml(paper.memo)}</textarea>
            <div class="mt-2 flex items-center gap-3">
              <button type="button" class="memo-save-btn rounded bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-indigo-700">GitHub Issueで保存</button>
              <button type="button" class="memo-cancel-btn text-xs text-slate-400 hover:underline">キャンセル</button>
            </div>
            <p class="mt-2 text-xs text-slate-400">押すとGitHubのIssue作成画面が新しいタブで開きます。内容を確認して送信すると、数分以内にこのメモが自動反映されます。</p>
          </div>
        </div>
      </article>
    `;

    const el = wrapper.firstElementChild as HTMLElement;
    const favBtn = el.querySelector<HTMLElement>(".favorite-toggle");
    const laterBtn = el.querySelector<HTMLElement>(".readlater-toggle");
    if (favBtn) applyToggleState(favBtn, favorites.has(paper.id));
    if (laterBtn) applyToggleState(laterBtn, readLater.has(paper.id));
    return el;
  }

  grid.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;

    const favBtn = target.closest<HTMLElement>(".favorite-toggle");
    if (favBtn) {
      const card = favBtn.closest<HTMLElement>(".paper-card")!;
      const id = card.dataset.id!;
      const active = favorites.has(id);
      if (active) favorites.delete(id);
      else favorites.add(id);
      saveIdSet(FAVORITES_KEY, favorites);
      applyToggleState(favBtn, !active);
      applyFilters();
      return;
    }

    const laterBtn = target.closest<HTMLElement>(".readlater-toggle");
    if (laterBtn) {
      const card = laterBtn.closest<HTMLElement>(".paper-card")!;
      const id = card.dataset.id!;
      const active = readLater.has(id);
      if (active) readLater.delete(id);
      else readLater.add(id);
      saveIdSet(READLATER_KEY, readLater);
      applyToggleState(laterBtn, !active);
      applyFilters();
      return;
    }

    const editToggle = target.closest<HTMLElement>(".memo-edit-toggle");
    if (editToggle) {
      const section = editToggle.closest<HTMLElement>("[data-memo-section]")!;
      section.querySelector(".memo-edit-form")!.classList.toggle("hidden");
      return;
    }

    const cancelBtn = target.closest<HTMLElement>(".memo-cancel-btn");
    if (cancelBtn) {
      const section = cancelBtn.closest<HTMLElement>("[data-memo-section]")!;
      const textarea = section.querySelector<HTMLTextAreaElement>(".memo-textarea")!;
      const currentText = section.querySelector<HTMLElement>("[data-memo-text]")?.textContent?.trim() ?? "";
      textarea.value = currentText === "メモなし" ? "" : currentText;
      section.querySelector(".memo-edit-form")!.classList.add("hidden");
      return;
    }

    const saveBtn = target.closest<HTMLElement>(".memo-save-btn");
    if (saveBtn) {
      const card = saveBtn.closest<HTMLElement>(".paper-card")!;
      const section = saveBtn.closest<HTMLElement>("[data-memo-section]")!;
      const textarea = section.querySelector<HTMLTextAreaElement>(".memo-textarea")!;
      const paperId = card.dataset.id!;
      const paperTitle = card.dataset.title ?? "";

      const params = new URLSearchParams({
        template: "memo-update.yml",
        title: `[memo] ${paperTitle}`,
        paper_id: paperId,
        memo: textarea.value,
      });
      window.open(`https://github.com/${githubRepo}/issues/new?${params.toString()}`, "_blank", "noopener");
      return;
    }
  });

  function isFilterActive(): boolean {
    return (
      !!searchInput.value.trim() ||
      !!categoryFilter.value ||
      !!conferenceFilter.value ||
      !!memoFilter.value ||
      tagCheckboxes.some((cb) => cb.checked) ||
      favoritesOnlyFilter.checked ||
      readlaterOnlyFilter.checked
    );
  }

  function matchesPaper(paper: RemotePaper, opts: {
    query: string;
    category: string;
    conference: string;
    memo: string;
    activeTags: string[];
    tagMode: string;
    favoritesOnly: boolean;
    readLaterOnly: boolean;
  }): boolean {
    const tags = paper.tags || [];
    const hasMemo = paper.memo.trim().length > 0;
    const searchBlob = [paper.title, paper.authors.join(" "), paper.abstract, tags.join(" ")].join(" ").toLowerCase();

    const matchesSearch = !opts.query || searchBlob.includes(opts.query);
    const matchesCategory = !opts.category || paper.category === opts.category;
    const matchesConference = !opts.conference || paper.conference === opts.conference;
    const matchesMemo = !opts.memo || (opts.memo === "with" ? hasMemo : !hasMemo);
    const matchesTags =
      opts.activeTags.length === 0 ||
      (opts.tagMode === "and" ? opts.activeTags.every((t) => tags.includes(t)) : opts.activeTags.some((t) => tags.includes(t)));
    const matchesFavorites = !opts.favoritesOnly || favorites.has(paper.id);
    const matchesReadLater = !opts.readLaterOnly || readLater.has(paper.id);

    return matchesSearch && matchesCategory && matchesConference && matchesMemo && matchesTags && matchesFavorites && matchesReadLater;
  }

  function sortPapers(list: RemotePaper[]): RemotePaper[] {
    const sorted = [...list];
    if (sortMode === "award") {
      sorted.sort((a, b) => {
        const diff = Number(!!b.award) - Number(!!a.award);
        if (diff !== 0) return diff;
        return b.published_date.localeCompare(a.published_date);
      });
    } else {
      sorted.sort((a, b) => b.published_date.localeCompare(a.published_date));
    }
    return sorted;
  }

  const RESULTS_BATCH_SIZE = 60;
  let globalResults: RemotePaper[] = [];
  let renderedGlobalCount = 0;
  let requestToken = 0;

  function renderNextBatch() {
    const nextSlice = globalResults.slice(renderedGlobalCount, renderedGlobalCount + RESULTS_BATCH_SIZE);
    for (const paper of nextSlice) {
      grid.appendChild(renderCardElement(paper));
    }
    renderedGlobalCount += nextSlice.length;
    loadMoreBtn.classList.toggle("hidden", renderedGlobalCount >= globalResults.length);
  }

  loadMoreBtn.addEventListener("click", renderNextBatch);

  async function applyFilters() {
    if (!isFilterActive()) {
      requestToken += 1; // invalidate any in-flight global search
      grid.replaceChildren(...originalCards);
      pageRangeLabel.classList.remove("hidden");
      pageNav.classList.remove("hidden");
      loadMoreBtn.classList.add("hidden");
      resultCount.textContent = `${originalCards.length}件を表示中`;
      emptyState.classList.add("hidden");
      return;
    }

    pageRangeLabel.classList.add("hidden");
    pageNav.classList.add("hidden");
    loadMoreBtn.classList.add("hidden");
    resultCount.textContent = "全件検索中...";
    emptyState.classList.add("hidden");

    const token = ++requestToken;
    const index = await ensureIndexLoaded();
    if (token !== requestToken) return; // a newer filter change superseded this one

    const opts = {
      query: searchInput.value.trim().toLowerCase(),
      category: categoryFilter.value,
      conference: conferenceFilter.value,
      memo: memoFilter.value,
      activeTags: tagCheckboxes.filter((cb) => cb.checked).map((cb) => cb.dataset.tag!),
      tagMode: tagModeSelect.value,
      favoritesOnly: favoritesOnlyFilter.checked,
      readLaterOnly: readlaterOnlyFilter.checked,
    };

    globalResults = sortPapers(index.filter((p) => matchesPaper(p, opts)));
    renderedGlobalCount = 0;
    grid.replaceChildren();
    renderNextBatch();

    resultCount.textContent = `全${index.length}件中 ${globalResults.length}件がヒット`;
    emptyState.classList.toggle("hidden", globalResults.length !== 0);
  }

  let searchDebounceTimer: ReturnType<typeof setTimeout> | undefined;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchDebounceTimer);
    searchDebounceTimer = setTimeout(applyFilters, 200);
  });

  [categoryFilter, conferenceFilter, memoFilter].forEach((el) => el.addEventListener("change", applyFilters));
  tagCheckboxes.forEach((cb) => cb.addEventListener("change", applyFilters));
  tagModeSelect.addEventListener("change", applyFilters);
  favoritesOnlyFilter.addEventListener("change", applyFilters);
  readlaterOnlyFilter.addEventListener("change", applyFilters);

  resetButton.addEventListener("click", () => {
    searchInput.value = "";
    categoryFilter.value = "";
    conferenceFilter.value = "";
    memoFilter.value = "";
    tagCheckboxes.forEach((cb) => (cb.checked = false));
    tagModeSelect.value = "or";
    favoritesOnlyFilter.checked = false;
    readlaterOnlyFilter.checked = false;
    applyFilters();
  });

  applyFilters();
</script>
