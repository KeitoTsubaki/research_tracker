---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "研究論文トラッカー",
  description = "マルチエージェント強化学習・協調ロボット搬送・自動運転関連の論文を自動収集するトラッカー",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title={title} href={`${import.meta.env.BASE_URL}rss.xml`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
